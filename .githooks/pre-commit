#!/usr/bin/env bash

# Maximum file size in bytes (100 MB)
MAX_SIZE=$((100 * 1024 * 1024))

# Use git diff --cached --name-only -z to handle files with spaces
# We iterate through staged files and check their size in the index
git diff --cached --name-only -z | while read -r -d $'\0' file; do
    # Skip if file was deleted (git cat-file will fail)
    if [ ! -f "$file" ]; then
        continue
    fi
    
    # Get the size of the staged content
    size=$(git cat-file -s ":$file")
    
    if [ "$size" -gt "$MAX_SIZE" ]; then
        echo "Error: File '$file' is $((size / 1024 / 1024)) MB, which exceeds the 100 MB limit."
        echo "Commit aborted."
        exit 1
    fi
done || exit 1

exit 0
